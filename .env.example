# Supabase — get from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App
VITE_APP_NAME=MamãeApp
VITE_APP_URL=http://localhost:5173

# Web Push / VAPID — generate with: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY is exposed to the frontend (safe to commit once generated)
# VAPID_PRIVATE_KEY and VAPID_SUBJECT go only in Supabase Edge Function secrets
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-base64url
VAPID_SUBJECT=mailto:admin@mamaeapp.com
